# ============================================================
# Garry Micro Dev Utilities — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All VITE_ prefixed variables are exposed to the browser.
# Do NOT put secrets that should stay server-side here.
# ============================================================

# --- App -----------------------------------------------------------

# Log level for the structured logger.
# Values: debug | info | warn | error
# Default: "debug" in development, "info" in production.
VITE_LOG_LEVEL=

# --- GitHub API (for update-repo-descriptions.js script) ------------

# GitHub Personal Access Token (create at https://github.com/settings/tokens, scope: repo)
GITHUB_TOKEN=your_github_pat_here
# GitHub username (optional, for script defaults)
GITHUB_USERNAME=your_username
